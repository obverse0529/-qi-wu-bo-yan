# 启物博言智慧博物馆系统 - 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ============== 应用配置 ==============
APP_NAME=启物博言智慧博物馆系统
APP_VERSION=1.0.0
DEBUG=true
API_PREFIX=/api/v1

# ============== 服务器 ==============
HOST=0.0.0.0
PORT=8000

# ============== PostgreSQL ==============
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/qiwu
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/qiwu

# ============== Neo4j ==============
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ============== Milvus ==============
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=artifact_documents

# ============== MinIO / S3 ==============
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=qiwu-artifacts
S3_PUBLIC_URL=http://localhost:9000

# ============== LLM - Gemma ==============
GEMMA_MODEL_NAME=google/gemma-3-4b-it
GEMMA_DEVICE=cuda
GEMMA_MAX_LENGTH=8192
GEMMA_QUANTIZATION=int4  # None, int4, int8

# ============== 3D Model - Hunyuan3D ==============
HUNYAN3D_REPO_ID=Tencent/Hunyuan3D
HUNYAN3D_DEVICE=cuda

# ============== RAG ==============
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
RAG_TOP_K=5

# ============== 文件上传 ==============
UPLOAD_MAX_SIZE_MB=50
ALLOWED_IMAGE_TYPES=["image/jpeg","image/png","image/webp"]

# ============== CORS ==============
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
