# ============================================
# 启物博言 Docker Compose 环境变量
# 复制此文件为 .env.docker.local 并修改实际值
# ============================================

# ---------- 全局 ----------
COMPOSE_PROJECT_NAME=qiwu

# ---------- PostgreSQL ----------
POSTGRES_DB=qiwu
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_PORT=5432

# ---------- Neo4j ----------
NEO4J_AUTH=neo4j/change-me-neo4j
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# ---------- Milvus ----------
MILVUS_HTTP_PORT=9091

# ---------- MinIO ----------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---------- Redis ----------
REDIS_PORT=6379

# ---------- 应用 ----------
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_PREFIX=/api/v1

# ---------- 前端 ----------
FRONTEND_PORT=3000
VITE_API_BASE=http://localhost:8000/api/v1

# ---------- Nginx ----------
NGINX_PORT=80
NGINX_SSL_PORT=443

# ---------- S3 / MinIO (后端使用) ----------
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change-me-minio
S3_BUCKET=qiwu-artifacts

# ---------- LLM ----------
GEMMA_MODEL_NAME=google/gemma-3-4b-it
GEMMA_DEVICE=cuda
GEMMA_QUANTIZATION=int4

# ---------- RAG ----------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
RAG_TOP_K=5

# ---------- 文件上传 ----------
UPLOAD_MAX_SIZE_MB=50
ALLOWED_IMAGE_TYPES=["image/jpeg","image/png","image/webp"]

# ---------- CORS ----------
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
